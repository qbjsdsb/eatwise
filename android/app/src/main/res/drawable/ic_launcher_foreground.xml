<?xml version="1.0" encoding="utf-8"?>
<!--
  自适应图标前景：白色「同心圆环 + 中心圆点」抽象几何（M17 重设计）。

  设计理念（M17 用户决策：M3 抽象几何 + 紫橙双色渐变）：
  - 同心圆环 = 镜头光圈（拍照识别核心功能）+ 份量刻度（营养记录）
  - 中心圆点 = 一餐的圆满 / 焦点锁定的食物
  - 顶部 8dp 缺口 = "慢"的呼吸感（破规的精致，避免完全对称的呆板）
  - 纯白前景在紫橙渐变背景上高对比，缩放到 48dp 仍清晰

  设计哲学 "Chromatic Mindful"：
  - 紫色 = 觉知（识别营养），橙色 = 温度（品味食物）
  - 几何克制：每个形都有份量，无多余装饰
  - master-level execution：粗线条 ≥4dp 保证缩放可识别性

  画布 108×108dp，安全区 66×66（中心 54,54，半径 33）。
  实际几何范围（留 4dp 余量，半径 29 内）：
  - 外环：外径 50dp（半径 25dp，距安全区边缘 8dp），环宽 6dp，内径 19dp
  - 顶部缺口：8dp 宽（x=50-58，y=29-35）
  - 中心圆点：直径 16dp（半径 8dp），中心 (54,54)

  path 几何说明：
  - 外环 path：从缺口左上 (50,29) 顺时针画外圆大弧 350° 到缺口右上 (58,29)，
    直线下到 (58,35)，逆时针画内圆大弧 350° 到 (50,35)，闭合形成"有缺口的环"
  - 中心圆 path：从左点 (46,54) 画两个半圆顺时针形成完整圆

  monochrome 兼容（Android 13+ 主题图标）：
  - 前景纯白 alpha 通道，无渐变在前景层
  - 系统染色时背景渐变被忽略，前景独立可识别（同心圆环+中心圆点的剪影）

  M15 → M17 演进：M15 餐叉+餐刀具象 → M17 同心圆环+圆点抽象（用户反馈"图标实在太丑"重设计）
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 外环（带顶部 8dp 缺口）：
         M50,29 起点（缺口左上角）
         A25,25 0 1 1 58,29 外圆顺时针大弧 350° 到缺口右上角
         L58,35 直线下到缺口右下角
         A19,19 0 1 0 50,35 内圆逆时针大弧 350° 到缺口左下角
         Z 闭合（直线回到起点，形成缺口左侧） -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M50,29 A25,25 0 1 1 58,29 L58,35 A19,19 0 1 0 50,35 Z" />

    <!-- 中心圆点（直径 16dp，半径 8dp，中心 54,54）：
         M46,54 左点
         A8,8 0 1 1 62,54 上半圆顺时针到右点
         A8,8 0 1 1 46,54 下半圆顺时针回左点
         Z 闭合 -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M46,54 A8,8 0 1 1 62,54 A8,8 0 1 1 46,54 Z" />
</vector>
