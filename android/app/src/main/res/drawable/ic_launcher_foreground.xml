<?xml version="1.0" encoding="utf-8"?>
<!--
  自适应图标前景：白色「碗 + 蒸汽」几何图形。
  语义：热气腾腾的碗 → 慢慢吃 → 温馨大方。

  设计要点（Google Material Symbols 风格）：
  - 前景纯白 #FFFFFF，与暖橙背景高对比度
  - 几何极简：碗身梯形 + 碗口直线 + 2 道 S 形蒸汽（stroke 风格）
  - 全部圆角（Material Symbols 特征：rounded corners / linecaps）
  - 缩放到 48dp 仍清晰（stroke 宽度 4dp，碗身大块 fill）

  画布 108x108dp，安全区 66x66（中心 54,54，半径 33）。
  实际图形范围：x=30-78（宽 48），y=24-80（高 56），整体水平居中、垂直微偏上。
  蒸汽顶 y=24，碗底 y=80，碗口 y=52，均在安全区 21-87 内。

  几何构成：
  - 蒸汽（2 道 S 形上升波浪，stroke 圆角）：
      · 左：x≈44，y=24-50，S 形曲线
      · 右：x≈64，y=24-50，S 形曲线（与左镜像）
  - 碗口：横直线 y=52，x=30-78
  - 碗身：梯形（上宽 48、下宽 34、高 26）+ 碗底椭圆弧圆角
      · 上端 (30,52)-(78,52)
      · 下端 (37,78)-(71,78)，两端用 A 17,4 椭圆弧连接成圆角底
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 蒸汽：2 道 S 形上升波浪，stroke 风格（Material Symbols outlined） -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 44,50 C 40,44 48,40 44,34 C 42,30 46,26 44,24" />

    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 64,50 C 60,44 68,40 64,34 C 62,30 66,26 64,24" />

    <!-- 碗：碗口（横直线）+ 碗身（梯形）+ 碗底（椭圆弧圆角），单 path fill -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 30,52 L 78,52 L 71,78 A 17,4 0 0,1 37,78 Z" />
</vector>
