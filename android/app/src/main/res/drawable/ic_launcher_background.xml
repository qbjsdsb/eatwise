<?xml version="1.0" encoding="utf-8"?>
<!-- 自适应图标背景：Material Deep Orange 400 暖橙纯色。
     选色理由（用户反馈"青莲色太丑，要更谷歌、温馨大方"）：
     - Deep Orange 400 是 Material Design 标准色板成员，Google Workspace 常用暖色之一
       （Gmail 红 / Maps 黄 / Photos 橙 / Calendar 红都用暖色系传递"活力"）
     - 暖橙在食欲心理学上是"食物色"（番茄 / 橙子 / 蛋黄），契合"慢慢吃"饮食 App 语义
     - 纯色（无渐变）符合 Material Symbols 极简风格，缩放到 48dp 仍清晰
     - 与品牌主题种子色（莲花青绿）解耦，启动器图标走独立暖色系更醒目
     M15-A2：颜色引用 colors.xml 的 ic_launcher_background，便于后续主题化 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ic_launcher_background" />
</shape>
